# .env.prod.example
#
# QUOI : Modèle de variables pour `compose.prod.yaml` (secrets, APIs, domaine).
#
# COMMENT : Copier vers `.env.prod` (non versionné) ; remplacer les `__REMPLIR__`.
#
# OÙ : Racine du dépôt sur le serveur de production.
#
# POURQUOI : Documenter les clés attendues sans committer de secrets.
#
# Usage : cp .env.prod.example .env.prod && nano .env.prod
# APP_SECRET : openssl rand -hex 32
# POSTGRES_PASSWORD : openssl rand -base64 24 | tr -d '/=+'

############################
# Symfony / Application    #
############################
APP_SECRET=__REMPLIR_AVEC_openssl_rand_hex_32__

############################
# Domaine & TLS            #
############################
SITE_DOMAIN=opale.news
ACME_EMAIL=admin@opale.news

############################
# Base de données          #
############################
POSTGRES_VERSION=16
POSTGRES_DB=opale_news
POSTGRES_USER=opale
POSTGRES_PASSWORD=__REMPLIR_AVEC_UN_MOT_DE_PASSE_FORT__

############################
# Pinecone (vector index)  #
############################
PINECONE_API_KEY=__NOUVELLE_CLE_GENEREE_DANS_LA_CONSOLE_PINECONE__
PINECONE_INDEX_URL=https://opalenews-mvp-p02rxkr.svc.aped-4627-b74a.pinecone.io

############################
# Google APIs              #
############################
# Restreindre cette clé au domaine opale.news dans la console GCP (HTTP referrer).
GMAPS_API_KEY=__NOUVELLE_CLE_MAPS_RESTREINTE_AU_DOMAINE__
GEMINI_API_KEY=__NOUVELLE_CLE_GEMINI__

############################
# reCAPTCHA                #
############################
RECAPTCHA_SITE_KEY=__NOUVELLE_CLE_SITE__
RECAPTCHA_SECRET_KEY=__NOUVELLE_CLE_SECRETE__

############################
# Mailer                   #
############################
# Exemples :
#   MAILER_DSN=smtp://user:password@smtp.mailgun.org:587
#   MAILER_DSN=sendgrid+smtp://apikey:KEY@default
MAILER_DSN=null://null
